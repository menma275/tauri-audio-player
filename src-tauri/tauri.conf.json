{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Player",
  "version": "0.1.0",
  "identifier": "com.mp3player.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Player",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost data:; media-src 'self' asset: https://asset.localhost http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
